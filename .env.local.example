# Gmail API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Claude API
ANTHROPIC_API_KEY=

# Encrypts Gmail access/refresh tokens at rest. Generate with:
#   openssl rand -base64 32
# Rotating this makes existing stored tokens undecryptable — every user
# would have to reconnect Gmail.
TOKEN_ENCRYPTION_KEY=

# Signs the OAuth `state` param and digest-feedback links. Generate with:
#   openssl rand -base64 32
OAUTH_STATE_SECRET=

# Set to "true" ONLY after scripts/backfill-token-encryption.ts reports zero
# plaintext rows. It turns a legacy unencrypted token from a silent
# passthrough into a hard error. Setting it early breaks every user whose
# token hasn't been backfilled yet. See SECURITY.md.
TOKENS_REQUIRE_ENCRYPTION=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk — get these from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=
NEXT_PUBLIC_CLERK_SIGN_UP_URL=
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Posthog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_INVITE_ONLY=

# Vercel CRON
CRON_SECRET=

# SENTRY
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# For admin portal
ADMIN_EMAILS=